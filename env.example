# Server
PORT=3001
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=ponches
DB_CONN_LIMIT=10

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=8h

# Email (supervisor alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
# The address used in the `from:` field for all alert emails.
# Company auto-closure copies are sent to `companies.notification_email`.
# `MAIL_FROM` is only used as a fallback recipient if the DB field is empty/unavailable.
MAIL_FROM="Ponches App" <your-email@example.com>

# Fallback attendance-alert recipient if no company ADMIN has an email (profile PUT /employees).
# Primary recipients: all employees with role ADMIN and a non-empty email in the database.
SUPER_MANAGER_EMPLOYEE_CODE=SUP001

# FCM — prefer HTTP v1 (Firebase Admin). Download a service account JSON (Project settings → Service accounts).
# Use either a file path or the standard GCP variable (same JSON file):
FIREBASE_SERVICE_ACCOUNT_PATH=
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-adminsdk.json
# Optional: paste the full JSON on one line (escape quotes) for hosts that cannot mount files:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Legacy HTTP API (deprecated by Google). Used only if no service account is configured above.
FCM_SERVER_KEY=

# Uploads
UPLOAD_DIR=./uploads

# Invite links base URL (e.g. https://api.ponches.com). Empty = use request Host.
INVITE_BASE_URL=

