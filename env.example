# Server
PORT=3001
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=ponches
DB_CONN_LIMIT=10

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=8h

# Email (supervisor alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
MAIL_FROM="Ponches App" <your-email@example.com>

# Optional push notifications (FCM)
FCM_SERVER_KEY=

# Uploads
UPLOAD_DIR=./uploads

